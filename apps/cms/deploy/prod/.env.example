# LinkSites CMS production deploy pointers. Commit secret names only.
# Copy to deploy/prod/.env on the host; runtime secrets render via GSM.

NODE_ENV=production
PORT=3000
PAYLOAD_PUBLIC_SERVER_URL=https://cms.linktrend.internal
PAYLOAD_CACHE_TTL_MS=600000
PAYLOAD_CACHE_CAPACITY=200
DRAFT_MAX_AGE_DAYS=30

# Traefik routing
TRAEFIK_ROUTER_NAME=linksites-cms
TRAEFIK_HOST=cms.linktrend.internal
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# GSM / host mount
GCP_PROJECT_ID=linkbot-901208
GOOGLE_APPLICATION_CREDENTIALS=/etc/linktrend/gcp/linktrend-service-account.json
GOOGLE_APPLICATION_CREDENTIALS_HOST_PATH=/etc/linktrend/gcp/linktrend-service-account.json

# Optional integrations
N8N_WEBHOOK_URL=
REBUILD_WEBHOOK_URL=
SEARCH_INDEX_ENDPOINT=

# GSM-backed secrets
DATABASE_URI_SECRET_NAME=LINKSITES_CMS_DATABASE_URI
PAYLOAD_SECRET_SECRET_NAME=LINKSITES_PAYLOAD_SECRET_PROD
WEBHOOK_SECRET_SECRET_NAME=LINKSITES_WEBHOOK_SECRET_PROD
YOUTUBE_WEBHOOK_SECRET_SECRET_NAME=LINKSITES_YOUTUBE_WEBHOOK_SECRET_PROD
N8N_WEBHOOK_SECRET_SECRET_NAME=LINKSITES_N8N_WEBHOOK_SECRET_PROD
