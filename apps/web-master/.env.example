# ============================================================================
# LINKTREND MASTER TEMPLATE - ENVIRONMENT VARIABLES
# ============================================================================
# This file documents all environment variables used in the Master Template.
# Copy this file to .env.local and fill in your values.
#
# IMPORTANT:
# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# - Server-only variables (no NEXT_PUBLIC_ prefix) are kept private
# - See /docs/ENV_VARS_COMPLETE.md for detailed documentation
# ============================================================================

# ============================================================================
# NEXT.JS ENVIRONMENT
# ============================================================================
# Automatically set by Next.js, but can be overridden for testing

# Node environment (development, production, test)
NODE_ENV=development

# ============================================================================
# SITE CONFIGURATION
# ============================================================================
# Core site identity and branding
# REQUIRED for production deployment

# Site name/brand (visible to users)
NEXT_PUBLIC_SITE_NAME=Company

# Site URL (required for SEO, absolute URLs, and Open Graph)
# MUST be set to your production domain before deploying
NEXT_PUBLIC_SITE_URL=https://example.com

# Company legal name (for legal pages, footer)
NEXT_PUBLIC_COMPANY_LEGAL_NAME=Company Inc.

# Company contact email (for contact forms, footer)
NEXT_PUBLIC_COMPANY_EMAIL=hello@example.com

# Company phone number (optional, for contact page)
NEXT_PUBLIC_COMPANY_PHONE=

# Site ID for multi-site deployments (optional)
SITE_ID=

# ============================================================================
# CMS CONFIGURATION
# ============================================================================
# Content Management System settings

# CMS provider type: 'payload' or 'mock'
# Use 'mock' for development with local JSON data
# Use 'payload' for production with Payload CMS
NEXT_PUBLIC_CMS_PROVIDER=mock

# Payload CMS server URL (public, client-side accessible)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Payload CMS base URL (server-side convenience; used by repository layer)
PAYLOAD_BASE_URL=http://localhost:3000

# Payload CMS API URL (public, client-side accessible)
NEXT_PUBLIC_PAYLOAD_API_URL=http://localhost:3000

# Payload CMS API key (server-side only, for authenticated requests)
# KEEP THIS SECRET - do not prefix with NEXT_PUBLIC_
PAYLOAD_API_KEY=

# Local dev fallback tenant (optional). In shared-platform mode, tenant is
# resolved by hostname via the CMS `site-domains` mapping.
DEFAULT_SITE_ID=

# ============================================================================
# THEME CONFIGURATION
# ============================================================================
# Visual theme and design system settings

# Default theme variant: 'default', 'dark', 'accent', or 'light'
NEXT_PUBLIC_DEFAULT_THEME=default

# Allow users to switch themes (true/false)
NEXT_PUBLIC_ALLOW_THEME_SWITCHING=true

# Legacy theme ID support
DEFAULT_THEME_ID=default

# ============================================================================
# ANALYTICS & TRACKING CONFIGURATION
# ============================================================================
# Privacy-compliant analytics with consent gating
# All analytics scripts only load AFTER explicit user consent

# Google Analytics 4 (GA4)
# Get your Measurement ID from: https://analytics.google.com/
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager (GTM)
# Get your Container ID from: https://tagmanager.google.com/
# Format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# Facebook Pixel
# Get your Pixel ID from: https://business.facebook.com/
# Format: numeric ID
NEXT_PUBLIC_FB_PIXEL_ID=

# LinkedIn Insight Tag
# Get your Partner ID from: https://www.linkedin.com/campaignmanager/
# Format: numeric ID
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# Hotjar (Heatmaps & Session Recording)
# Get your Site ID from: https://insights.hotjar.com/
# Format: numeric ID
NEXT_PUBLIC_HOTJAR_ID=

# Custom Analytics Endpoint (Optional)
# For self-hosted or custom analytics solutions
NEXT_PUBLIC_ANALYTICS_ENDPOINT=

# ============================================================================
# SOCIAL MEDIA
# ============================================================================
# Social media profiles and handles

# Twitter/X handle (include @)
NEXT_PUBLIC_TWITTER_HANDLE=@company

# LinkedIn company page URL
NEXT_PUBLIC_LINKEDIN_URL=

# Facebook page URL
NEXT_PUBLIC_FACEBOOK_URL=

# Instagram profile URL
NEXT_PUBLIC_INSTAGRAM_URL=

# YouTube channel URL
NEXT_PUBLIC_YOUTUBE_URL=

# ============================================================================
# EXTERNAL APPLICATION URLS
# ============================================================================
# Links to external applications and services

# Main application login URL
NEXT_PUBLIC_APP_LOGIN_URL=https://app.example.com/login

# Main application signup URL
NEXT_PUBLIC_APP_SIGNUP_URL=https://app.example.com/signup

# Admin/dashboard login URL
NEXT_PUBLIC_ADMIN_LOGIN_URL=https://admin.example.com/login

# Support portal URL (optional)
NEXT_PUBLIC_SUPPORT_URL=

# Documentation URL (optional)
NEXT_PUBLIC_DOCS_URL=

# API base URL (if separate from site, optional)
NEXT_PUBLIC_API_URL=

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable specific features
# Set to 'false' to disable, 'true' or omit to enable

# Cookie consent banner
NEXT_PUBLIC_ENABLE_COOKIE_CONSENT=true

# Newsletter signup forms
NEXT_PUBLIC_ENABLE_NEWSLETTER=true

# Live chat widget (requires integration)
NEXT_PUBLIC_ENABLE_LIVE_CHAT=false

# Blog/resources section
NEXT_PUBLIC_ENABLE_BLOG=true

# Case studies section
NEXT_PUBLIC_ENABLE_CASE_STUDIES=true

# Pricing page
NEXT_PUBLIC_ENABLE_PRICING=true

# Internationalization (i18n)
NEXT_PUBLIC_ENABLE_I18N=true

# ============================================================================
# CONTACT FORM & WEBHOOKS
# ============================================================================
# Contact form submission handling

# Contact form webhook URL (N8N, Zapier, Make, or custom endpoint)
# KEEP THIS SECRET - do not prefix with NEXT_PUBLIC_
CONTACT_WEBHOOK_URL=

# Contact form webhook secret for authentication
# KEEP THIS SECRET - do not prefix with NEXT_PUBLIC_
CONTACT_WEBHOOK_SECRET=

# Fallback email for contact form submissions (if webhook fails)
# KEEP THIS SECRET - do not prefix with NEXT_PUBLIC_
CONTACT_FALLBACK_EMAIL=

# Contact form API endpoint (default: /api/contact)
CONTACT_FORM_ENDPOINT=/api/contact

# ============================================================================
# DATABASE & CACHING
# ============================================================================
# Database and caching configuration (optional)

# Redis connection URL (for caching, sessions, etc.)
# Format: redis://username:password@host:port
REDIS_URL=

# Database connection URL (if needed in future)
DATABASE_URL=

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
#
# MASTER TEMPLATE:
# - Set NEXT_PUBLIC_SITE_NAME and NEXT_PUBLIC_SITE_URL to generic values
# - Use NEXT_PUBLIC_CMS_PROVIDER=mock for development
# - Leave analytics IDs empty (clients will fill these)
# - Keep all feature flags enabled by default
#
# SECONDARY TEMPLATES:
# - Inherit all Master Template settings
# - Override NEXT_PUBLIC_SITE_NAME for vertical branding
# - Customize theme settings if needed
# - May disable certain features via feature flags
#
# CLIENT SITES:
# - MUST set NEXT_PUBLIC_SITE_NAME and NEXT_PUBLIC_SITE_URL
# - MUST configure CMS connection (PAYLOAD_API_URL, PAYLOAD_API_KEY)
# - SHOULD configure analytics (GA, GTM, etc.)
# - SHOULD configure contact form webhook
# - MAY customize theme and feature flags
#
# SECURITY REMINDERS:
# - Never commit .env.local or .env.production to version control
# - Keep API keys, secrets, and webhook URLs private
# - Use NEXT_PUBLIC_ prefix ONLY for values safe to expose to browsers
# - Rotate secrets regularly in production
# - Use different secrets for staging and production
#
# ============================================================================
