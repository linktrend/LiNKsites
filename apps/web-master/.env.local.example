PAYLOAD_BASE_URL=http://localhost:3002
# Optional: for private reads. Public sites can work without this if the CMS
# allows public reads scoped by ?site=<siteId>.
PAYLOAD_API_KEY=

# Used only for local dev / build-time fallback. In production shared-platform
# mode, tenant is resolved by hostname via the CMS `site-domains` mapping.
DEFAULT_SITE_ID=

NEXT_PUBLIC_CMS_PROVIDER=payload
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3002
NEXT_PUBLIC_PAYLOAD_API_URL=http://localhost:3002

