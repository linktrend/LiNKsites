  "usage": {
    "description": "How to use this theme configuration",
    "manual": {
      "step1": "Edit the color, typography, or other token values in the 'theme' object above",
      "step2": "Manually update src/styles/tokens.css with the new values",
      "step3": "Rebuild the site: pnpm build",
      "step4": "Test the changes in the browser"
    },
    "aiPrompt": {
      "description": "For AI agents: Use this file to generate themed sub-templates",
      "example": "To create a healthcare theme, copy values from industryPresets.healthcare into theme object, then update tokens.css accordingly"
    }
  },
  "cssVariableMapping": {
    "description": "How theme.json values map to CSS variables in tokens.css",
    "colors": {
      "primary": "--color-primary",
      "primaryForeground": "--color-primary-foreground",
      "background": "--color-background",
      "foreground": "--color-foreground",
      "muted": "--color-muted",
